# Blind Insight credentials (shared by both demo notebooks)
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Dataset and schema slugs are set in each notebook's config helper
# (get_fraud_demo_config / get_bc_demo_config), not here.

BI_EMAIL=<your-blind-insight-email>
BI_PASSWORD=<your-blind-insight-password>
BI_ORG=<your-org-slug>

# Optional: override proxy URL (defaults are set per notebook)
# BI_PROXY_URL=https://local.blindinsight.io
