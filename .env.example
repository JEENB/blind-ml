# Blind Insight configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

BI_BACKEND=proxy
BI_EMAIL=<your-blind-insight-email>
BI_PASSWORD=<your-blind-insight-password>
BI_ORG=<your-org-slug>
BI_DATASET=<your-dataset-slug>
BI_SCHEMA=train
BI_TEST_SCHEMA=test

# Hosted BI (breast cancer notebook — proxy points at app.blindinsight.io)
# BI_PROXY_URL=https://local.blindinsight.io
# BI_API_URL=http://localhost:8080

# Local BI server (fraud notebook — proxy points at local server)
# BI_FRAUD_PROXY_URL=http://localhost:3002
# BI_FRAUD_API_URL=http://localhost:8080
